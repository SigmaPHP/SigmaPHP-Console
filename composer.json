{
    "name": "sigmaphp/sigmaphp-console",
    "description": "Create powerful console apps",
    "keywords": [
        "SigmaPHP",
        "framework",
        "console",
        "cli",
        "terminal",
        "command-line"
    ],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SigmaPHP\\Console\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SigmaPHP\\Console\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Mohamed Yousef",
            "email": "engineer.mohamed.yossef@gmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "agashe/var-dumper": "^0.1.5"
    },
    "scripts": {
        "test": [
            "Composer\\Config::disableProcessTimeout",
            "./vendor/bin/phpunit tests/"
        ]
    }
}
